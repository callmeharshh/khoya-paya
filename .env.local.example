# Copy this to .env.local.

# --- SHIP / DEMO ON CLAUDE (default) ---
# This is the Claude Impact Lab — demo and submit on Claude.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the Claude model (defaults to claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# --- DEV-ONLY FALLBACK: test the pipeline before you have an Anthropic key ---
# Set LLM_PROVIDER=gemini to route through Gemini for local testing.
# SWITCH THIS BACK (or delete it) BEFORE THE EVENT.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash

# --- POLYGON ANCHORING (optional) ---
# Notarizes the audit-chain head hash on Polygon. Only a hash goes on-chain —
# never personal data. Without POLYGON_PRIVATE_KEY, anchoring is disabled and
# the app still runs. Use a Amoy TESTNET wallet funded from faucet.polygon.technology.
# POLYGON_PRIVATE_KEY=0x...            # a funded Amoy testnet wallet's private key
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
# POLYGON_EXPLORER=https://amoy.polygonscan.com
# POLYGON_NETWORK=Polygon Amoy testnet
