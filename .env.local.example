# Copy this to .env.local.

# --- SHIP / DEMO ON CLAUDE (default) ---
# This is the Claude Impact Lab — demo and submit on Claude.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the Claude model (defaults to claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# --- DEV-ONLY FALLBACK: test the pipeline before you have an Anthropic key ---
# Set LLM_PROVIDER=gemini to route through Gemini for local testing.
# SWITCH THIS BACK (or delete it) BEFORE THE EVENT.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash
